#!/usr/bin/env bash
set -euo pipefail

# ===== COLORS =====
RED="\e[91m"
GREEN="\e[92m"
YELLOW="\e[93m"
RESET="\e[0m"

# ===== LOGGING FUNCTIONS =====
log_info()  { printf "${GREEN}[INFO] %s${RESET}\n" "$1"; }
log_warn()  { printf "${YELLOW}[WARN] %s${RESET}\n" "$1"; }
log_error() { printf "${RED}[ERROR] %s${RESET}\n" "$1"; }

# ===== CHECK REQUIRED COMMANDS =====
require_cmd() {
    command -v "$1" >/dev/null 2>&1 || {
        log_error "$1 command not found. Please install it."
        exit 2
    }
}

# ===== CHECK IF DOCKER IMAGE EXISTS =====
image_exists() {
    docker image inspect "$1" >/dev/null 2>&1
}

# ===== BUILD LOCAL IMAGE =====
build_image() {
    local name="$1"
    local path="$2"

    if image_exists "$name"; then
        log_warn "Image $name already exists"
    else
        log_info "Building image $name..."
        docker build -t "$name" "$path"
    fi
}

# ===== PULL REMOTE IMAGE =====
pull_image() {
    local name="$1"

    if image_exists "$name"; then
        log_warn "Image $name already exists"
    else
        log_info "Pulling image $name..."
        docker pull "$name"
    fi
}

# ===== CLONE REPOSITORY AND BUILD IMAGE =====
clone_and_build() {
    local repo="$1"
    local tag="$2"
    local tmp_dir

    if image_exists "$tag"; then
        log_warn "Image $tag already exists"
        return
    fi

    tmp_dir=$(mktemp -d)

    log_info "Cloning repository $repo..."
    git clone --depth 1 "$repo" "$tmp_dir"

    log_info "Building image $tag..."
    docker build -t "$tag" "$tmp_dir"

    rm -rf "$tmp_dir"
}

# ===== LIST INSTALLED TOOLS =====
list_tools() {
    log_info "Installed tools (Docker images):"

    docker images --format "{{.Repository}}:{{.Tag}}" \
        | grep -E "$(whoami)|rustscan|metasploit" \
        | sort \
        | awk '{print " - " $0}' || log_warn "No tools found"
}

# ===== INSTALL TOOLS =====
install_tools() {
    local USER_TAG
    USER_TAG=$(whoami)

    log_info "Starting installation..."

    # Local builds
    build_image "$USER_TAG/nmap" "./nmap"
    build_image "$USER_TAG/sqlmap" "./sqlmap"
    build_image "$USER_TAG/theharvester" "./theHarvester"

    # Remote images
    pull_image "rustscan/rustscan"
    pull_image "metasploitframework/metasploit-framework"

    # Git-based builds
    clone_and_build "https://github.com/sullo/nikto.git" "$USER_TAG/nikto"
    clone_and_build "https://github.com/wpscanteam/wpscan.git" "$USER_TAG/wpscan"

    log_info "Installation completed ✅"

    list_tools
}

# ===== UNINSTALL TOOL =====
uninstall_tool() {
    local tool="${1:-}"

    # If no tool specified, show installed tools
    if [[ -z "$tool" ]]; then
        log_warn "No tool specified."
        list_tools
        printf "\nUsage: $0 uninstall <tool>\n"
        exit 2
    fi

    # Find matching images
    local matches
    matches=$(docker images --format "{{.Repository}}:{{.Tag}}" | grep -i "$tool" || true)

    if [[ -z "$matches" ]]; then
        log_warn "No installed tool matches: $tool"
        list_tools
        exit 2
    fi

    # If multiple matches found, ask user to refine
    local count
    count=$(echo "$matches" | wc -l)

    if [[ "$count" -gt 1 ]]; then
        log_warn "Multiple matches found:"
        echo "$matches" | awk '{print " - " $0}'
        log_warn "Please refine the tool name"
        exit 2
    fi

    local image="$matches"

    log_info "Removing image $image..."
    docker rmi "$image"

    log_info "Tool removed successfully ✅"
}

# ===== MAIN FUNCTION =====
main() {
    require_cmd docker
    require_cmd git

    case "${1:-}" in
        install)
            install_tools
            ;;
        uninstall)
            uninstall_tool "${2:-}"
            ;;
        list)
            list_tools
            ;;
        *)
            log_warn "Usage: $0 {install|uninstall <tool>|list}"
            exit 1
            ;;
    esac
}

main "$@"
