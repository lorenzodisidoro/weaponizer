#!/usr/bin/env bash
set -euo pipefail

# ===== COLORS =====
RED="\e[91m"
GREEN="\e[92m"
YELLOW="\e[93m"
RESET="\e[0m"

# ===== LOGGING =====
log_info()  { printf "${GREEN}[INFO] %s${RESET}\n" "$1"; }
log_warn()  { printf "${YELLOW}[WARN] %s${RESET}\n" "$1"; }
log_error() { printf "${RED}[ERROR] %s${RESET}\n" "$1"; }

# ===== CHECK DEPENDENCIES =====
require_cmd() {
    command -v "$1" >/dev/null 2>&1 || {
        log_error "$1 command missing. Install it first."
        exit 2
    }
}

# ===== IMAGE CHECK =====
image_exists() {
    docker image inspect "$1" >/dev/null 2>&1
}

# ===== INSTALL HELPERS =====
build_image() {
    local name="$1"
    local path="$2"

    if image_exists "$name"; then
        log_warn "Image $name already exists"
    else
        log_info "Building $name..."
        docker build -t "$name" "$path"
    fi
}

pull_image() {
    local name="$1"

    if image_exists "$name"; then
        log_warn "Image $name already exists"
    else
        log_info "Pulling $name..."
        docker pull "$name"
    fi
}

clone_and_build() {
    local repo="$1"
    local tag="$2"
    local dir
    dir=$(mktemp -d)

    if image_exists "$tag"; then
        log_warn "Image $tag already exists"
        return
    fi

    log_info "Cloning $repo..."
    git clone --depth 1 "$repo" "$dir"

    log_info "Building $tag..."
    docker build -t "$tag" "$dir"

    rm -rf "$dir"
}

# ===== INSTALL =====
install_tools() {
    local USER_TAG
    USER_TAG=$(whoami)

    log_info "Starting installation..."

    # LOCAL BUILDS
    build_image "$USER_TAG/nmap" "./nmap"
    build_image "$USER_TAG/sqlmap" "./sqlmap"
    build_image "$USER_TAG/theharvester" "./theHarvester"

    # REMOTE IMAGES
    pull_image "rustscan/rustscan"
    pull_image "metasploitframework/metasploit-framework"

    # GIT BASED
    clone_and_build "https://github.com/sullo/nikto.git" "$USER_TAG/nikto"
    clone_and_build "https://github.com/wpscanteam/wpscan.git" "$USER_TAG/wpscan"

    log_info "Installation completed ✅"

    docker images | grep -E "$USER_TAG|rustscan|metasploit" || true
}

# ===== UNINSTALL =====
uninstall_tool() {
    local tool="$1"

    if [[ -z "$tool" ]]; then
        log_warn "Specify a tool (e.g. nmap, nikto)"
        exit 2
    fi

    local image
    image=$(docker images --format "{{.Repository}}:{{.Tag}}" | grep "$tool" | head -n 1 || true)

    if [[ -z "$image" ]]; then
        log_warn "No image found for $tool"
        exit 2
    fi

    log_info "Removing $image..."
    docker rmi "$image"
}

# ===== MAIN =====
main() {
    require_cmd docker
    require_cmd git

    case "${1:-}" in
        install)
            install_tools
            ;;
        uninstall)
            uninstall_tool "${2:-}"
            ;;
        *)
            log_warn "Usage: $0 {install|uninstall <tool>}"
            exit 1
            ;;
    esac
}

main "$@"
